# Copy to .env.local for local dev. .env.local is gitignored.

# The local Cloudflare Worker dev server (proxy.kanvis.app in prod).
NEXT_PUBLIC_PROXY_BASE=http://localhost:8787

# OpenRouter API key for the chat input ("describe a change").
# Get one at https://openrouter.ai/keys.
# Without this, the chat box returns an error but drag-handles still work.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional override. Defaults to deepseek/deepseek-v4-flash if unset.
# Other good picks: anthropic/claude-haiku-4-5, openai/gpt-4o-mini, google/gemini-2.5-flash-lite.
# Browse the catalog at https://openrouter.ai/models.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
